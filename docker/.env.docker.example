# =====================================================================
# .env.docker.example
# Copy to `.env.docker` and tweak. Used by docker-compose.
# Do NOT commit `.env.docker` (it may contain real secrets).
# =====================================================================

# --- Mode -----------------------------------------------------------------
# local | docker-local | cloud
PANGOLIN_MODE=docker-local

# --- Branding & routing ---------------------------------------------------
PROJECT_NAME=pangolin
# Host port for the reverse proxy (Caddy). UI will be at
# http://localhost:${PROXY_PORT}/  and  http://${PROJECT_NAME}.localhost:${PROXY_PORT}/
PROXY_PORT=8080

# Public hostname for `cloud` mode. Leave EMPTY for docker-local.
# Example for cloud: PUBLIC_HOSTNAME=pangolin.example.com
PUBLIC_HOSTNAME=

# --- Prefect URLs (browser must reach the API at this URL) ----------------
# In docker-local you usually keep this matching PROXY_PORT:
PREFECT_UI_API_URL=http://localhost:8080/api
# In cloud, set it to:  http://${PUBLIC_HOSTNAME}/api  (or https://)

# --- Bootstrap manifest ---------------------------------------------------
PANGOLIN_MANIFEST=prefect_manifest.yaml

# --- Schedule (optional) --------------------------------------------------
# PANGOLIN_CRON=0 6 * * *

# --- Real secrets consumed by the bootstrap manifest ----------------------
# Anything referenced as ${VAR} in prefect_manifest.yaml must be provided here.
AZURE_STORAGE_CONNECTION_STRING=
